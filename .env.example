# Copy this file to .env and fill in your values.
# Do NOT add quotes around values. Do NOT add spaces around =.

# =============================================================
# MODEL — choose ONE option and comment out the other
# =============================================================

# --- Option A: Ollama (Recommended — no rate limits, runs locally) ---
# Make sure Ollama is running and the model is pulled:
#   ollama pull llama3.2
#   ollama serve          (macOS Homebrew — leave terminal open)
GEMINI_MODEL=ollama/llama3.2

# --- Option B: Google Gemini (Backup — has rate limits on free tier) ---
# Get your API key at https://aistudio.google.com → Get API key
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash-lite
# GOOGLE_GENAI_USE_VERTEXAI=FALSE

# =============================================================
# COMET OPIK — required for both options above
# Get your key at https://www.comet.com/signup → Settings → API Keys
# =============================================================
OPIK_API_KEY=your_opik_api_key_here
OPIK_WORKSPACE=your_workspace_name_here
OPIK_PROJECT_NAME=engineering-faculty-assistant
